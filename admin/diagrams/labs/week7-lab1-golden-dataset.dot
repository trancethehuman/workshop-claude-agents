digraph AutoresearchLoop {
    rankdir=TB;
    newrank=true;
    splines=ortho;
    nodesep=0.8;
    ranksep=0.6;
    bgcolor="white";
    compound=true;
    node [fontname="Arial", fontsize=11, style="rounded,filled"];
    edge [fontname="Arial", fontsize=9];

    // Title
    label="Autoresearch Loop Architecture";
    labelloc="t";
    fontsize=14;
    fontname="Arial Bold";

    // Main container
    subgraph cluster_loop {
        label="Autoresearch Loop Architecture";
        style="rounded,filled";
        fillcolor="#F5F3FF";
        color="#7C3AED";
        fontname="Arial Bold";
        fontsize=12;

        // Skill node
        skill [label="Your Skill\n(SKILL.md)" shape=box fillcolor="#E0E7FF" color="#6366F1"];

        // Generate node
        generate [label="Generate N\nOutputs" shape=box fillcolor="#EFF6FF" color="#2563EB"];

        // Score node
        score [label="Score Each\nOutput" shape=box fillcolor="#EFF6FF" color="#2563EB"];

        // Analyze node
        analyze [label="Analyze\nFailures" shape=box fillcolor="#FEE2E2" color="#DC2626"];

        // Mutate node
        mutate [label="Mutate the\nSkill" shape=box fillcolor="#D1FAE5" color="#059669"];

        // Flow
        skill -> generate;
        generate -> score;
        score -> analyze;
        analyze -> mutate;
        mutate -> skill;

        // Key Insight
        insight [label="Key Insight: Treat prompt engineering like model training.\nDefine a loss function (eval), run experiments (generate\noutputs), optimize (mutate the prompt). Keep the winners." shape=box fillcolor="#FEF3C7" color="#D97706" style="filled"];
    }
}
